# Python
__pycache__/
*.pyc
.venv/

# Runtime state (regenerated by scripts)
scripts/state.json
scripts/last-flush.json
scripts/flush.log
scripts/compile.log
scripts/session-flush-*
scripts/flush-context-*

# Generated content (built up per-user by hooks and scripts)
daily/
knowledge/
raw/
processed/
Excalidraw/

# Reports (regenerated by lint)
reports/

# uv lock (regenerated by uv sync)
scripts/uv.lock

# Claude Code local settings
.claude/settings.local.json

# OS files
.DS_Store
Thumbs.db

# AI assistant local configs
.gemini/

# Obsidian — machine-specific state (exclude)
.obsidian/workspace.json
.obsidian/workspace-mobile.json
# Plugin user data (can contain secrets like API keys, certs)
.obsidian/plugins/*/data.json
# Platform-specific binaries
.obsidian/plugins/mcp-tools/bin/

# Secrets
.env
